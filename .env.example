RTSP_URL=rtsp://username:password@camera-host:554/stream
ALPR_RTSP_URL=
OPENALPR_SECRET_KEY=sk_your_secret_key_here
OPENALPR_COUNTRY=us
FRAME_WIDTH=960
PROCESS_EVERY_N_FRAMES=2
MIN_MOTION_AREA=2500
MIN_CONSECUTIVE_HITS=3
EVENT_IDLE_SECONDS=1.5
EVENT_MAX_SECONDS=60.0
PREBUFFER_SECONDS=2.0
POSTBUFFER_SECONDS=5.0
PREBUFFER_FRAMES=0
POSTBUFFER_FRAMES=0
UPLOAD_TOP_FRAMES=30
UPLOAD_MIN_SHARPNESS=80.0
EVENT_OUTPUT_DIR=/data/events
CAMERA_NAME=home-driveway
REQUEST_TIMEOUT_SECONDS=20
RECOGNIZE_VEHICLE=true
DEBUG_WINDOWS=false
FAST_ALPR_URL=http://fast-alpr:8090
FAST_ALPR_MIN_CONFIDENCE=0.75
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_IMAGES=3
WEB_HOST=0.0.0.0
WEB_PORT=8080
MAX_SAVED_IMAGES=50
FFMPEG_THREADS=1
STREAM_FPS=5
CAPTURE_BUFFER_SIZE=4
RTSP_CAPTURE_OPTIONS=rtsp_transport;tcp|max_delay;2000000|stimeout;10000000
ALPR_CAPTURE_FPS=2
# Normalized ROI: x1,y1,x2,y2 values from 0.0 to 1.0
ROI=0.05,0.35,0.95,0.95
# Optional normalized plate-only ROI for zoomed monitoring and cropped ALPR uploads
PLATE_ROI=0.30,0.45,0.80,0.75
