RTSP_URL=rtsp://username:password@camera-host:554/stream
HIKVISION_HOST=camera-host
HIKVISION_USER=username
HIKVISION_PASSWORD=password
USE_CAMERA_MOTION_API=true
HIKVISION_SCHEME=http
HIKVISION_PORT=0
HIKVISION_CHANNEL=1
HIKVISION_ALERT_ZONE_1_NAME=driveway
HIKVISION_ALERT_ZONE_1=0.05,0.35,0.55,0.95
HIKVISION_ALERT_ZONE_2_NAME=road
HIKVISION_ALERT_ZONE_2=0.55,0.18,0.95,0.52
HIKVISION_MOTION_SENSITIVITY=60
HIKVISION_EVENT_TIMEOUT_SECONDS=10
HIKVISION_REGISTRATION_REFRESH_SECONDS=60
HIKVISION_GRID_ROWS=18
HIKVISION_GRID_COLUMNS=22
OPENALPR_SECRET_KEY=
OPENALPR_COUNTRY=us
FRAME_WIDTH=960
PROCESS_EVERY_N_FRAMES=2
MIN_MOTION_AREA=2500
MIN_CONSECUTIVE_HITS=3
EVENT_IDLE_SECONDS=1.5
EVENT_MAX_SECONDS=60.0
PREBUFFER_SECONDS=10.0
POSTBUFFER_SECONDS=5.0
PREBUFFER_FRAMES=0
POSTBUFFER_FRAMES=0
VIDEO_FRAME_WIDTH=1920
VIDEO_FPS=8
VIDEO_PREBUFFER_MAX_FRAMES=8
UPLOAD_TOP_FRAMES=240
MANUAL_EXTRACT_IMAGE_COUNT=20
UPLOAD_MIN_SHARPNESS=80.0
HOST_DATA_DIR=/mnt/localdisk/pi-alpr
APP_ENV_FILE=/mnt/localdisk/pi-alpr/config/.env
TZ=Asia/Jerusalem
DOCKER_LOG_DRIVER=none
EVENT_OUTPUT_DIR=/data/events
IMAGE_OUTPUT_DIR=/data/events/images
VIDEO_OUTPUT_DIR=/data/events/videos
LOG_OUTPUT_DIR=/data/logs
EVENT_LOG_FILE=/data/logs/event-log.jsonl
CAMERA_NAME=home-driveway
REQUEST_TIMEOUT_SECONDS=20
RECOGNIZE_VEHICLE=true
DEBUG_WINDOWS=false
FAST_ALPR_URL=http://192.168.1.50:8090
FAST_ALPR_MIN_CONFIDENCE=0.75
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_IMAGES=3
TELEGRAM_ALERTS_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8080
MAX_SAVED_IMAGES=2000
FFMPEG_THREADS=1
STREAM_FPS=3
CAPTURE_BUFFER_SIZE=4
RTSP_CAPTURE_OPTIONS=rtsp_transport;tcp|max_delay;2000000|stimeout;10000000
SINGLE_FFMPEG_CAPTURE=true
FFMPEG_ANALYZE_DURATION=500000
FFMPEG_PROBE_SIZE=32768
RECORD_SEGMENT_SECONDS=2
RECORD_SEGMENT_RETENTION_SECONDS=300
ALPR_CAPTURE_FPS=0.5
ALPR_CAPTURE_WARMUP_SECONDS=1.5
LIVE_STREAM_WARMUP_SECONDS=1.5
# Normalized ROI: x1,y1,x2,y2 values from 0.0 to 1.0
ROI=0.05,0.35,0.95,0.95
# Optional normalized plate-only ROI for zoomed monitoring and cropped ALPR uploads
PLATE_ROI=0.30,0.45,0.80,0.75
